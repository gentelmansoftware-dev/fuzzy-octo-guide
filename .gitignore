# information for Eclipse / Flash Builder.
# Extensiones de sistema (Archivos invisibles que crea Windows/Mac)
.DS_Store
Thumbs.db
Desktop.ini

# Logs de errores
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.log

# Carpeta de dependencias (Si luego instalas librerías)
node_modules/
dist/
build/

# Variables de entorno (¡MUY IMPORTANTE!)
# Si en el futuro usas una API Key privada para Bitcoin, 
# se guardará en un archivo .env que NO debe subirse.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Archivos de editores de código
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj

